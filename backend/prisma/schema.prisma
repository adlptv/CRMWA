generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES
}

enum LeadSource {
  ORGANIC
  IG
  OTHER
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  DEAL
  CANCEL
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum BlastStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(SALES)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadsAssigned  Lead[]     @relation("AssignedTo")
  leadsCreatedBy Lead[]     @relation("AssignedBy")
  messages       Message[]
  blastTasks     BlastTask[]

  @@index([email])
  @@index([role])
}

model Lead {
  id          String     @id @default(uuid())
  name        String
  phone       String     @unique
  source      LeadSource @default(OTHER)
  status      LeadStatus @default(NEW)
  notes       String?
  assignedTo  String?
  assignedBy  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  assignedUser   User?      @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  assignedByUser User?      @relation("AssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)
  messages       Message[]
  blastLogs      BlastLog[]

  @@index([phone])
  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

model Message {
  id         String          @id @default(uuid())
  leadId     String
  phone      String
  direction  MessageDirection
  message    String          @db.Text
  timestamp  DateTime        @default(now())
  handledBy  String?

  lead    Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  handler User? @relation(fields: [handledBy], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([phone])
  @@index([timestamp])
  @@index([direction])
}

model BlastTask {
  id              String      @id @default(uuid())
  name            String
  message         String      @db.Text
  status          BlastStatus @default(PENDING)
  totalRecipients Int         @default(0)
  sentCount       Int         @default(0)
  failedCount     Int         @default(0)
  createdBy       String
  createdAt       DateTime    @default(now())
  completedAt     DateTime?

  creator User       @relation(fields: [createdBy], references: [id])
  logs    BlastLog[]

  @@index([status])
  @@index([createdBy])
}

model BlastLog {
  id           String    @id @default(uuid())
  blastTaskId  String
  leadId       String
  phone        String
  success      Boolean
  errorMessage String?
  sentAt       DateTime  @default(now())

  blastTask BlastTask @relation(fields: [blastTaskId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([blastTaskId])
  @@index([leadId])
}

# AI Agent Loop Configuration
# ===========================

# Project Settings
PROJECT_NAME="ai-agent-loop"
PROJECT_ROOT="C:\Users\MyBook Hype AMD\Downloads\automaton ai agent\ai-agent-loop"
REPO_URL=""
BRANCH_NAME="ai-dev"

# Quota Settings
QUOTA_CHECK_INTERVAL=60
QUOTA_CRITICAL_THRESHOLD=10
QUOTA_WARNING_THRESHOLD=25
QUOTA_STATUS_FILE="quota.status"
SHUTDOWN_FLAG="shutdown.flag"
COMMIT_LOCK="commit.lock"

# Restart Settings
MAX_RESTART_ATTEMPTS=3
RESTART_WINDOW_MINUTES=10
RESTART_DELAY_SECONDS=5

# Worker Settings
WORKER_COUNT=5
WORKER_DELAY=2
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY=5

# iFlow CLI Settings
IFLOW_PATH="iflow"
IFLOW_CONFIG_DIR=".iflow"

# Agent Mode Settings
AGENT_MODE_THINKING="glm-5"
AGENT_MODE_SMART="glm-5"

# Git Settings
GIT_USER_NAME="AI Agent"
GIT_USER_EMAIL="ai-agent@automaton.local"

# Log Settings
LOG_DIR="logs"
LOG_MAX_SIZE_MB=100
LOG_ROTATION_COUNT=5

# Safety Settings
ENABLE_SAFETY_CHECKS=true
ENABLE_BRANCH_ISOLATION=true
ENABLE_COMMIT_LOCK=true
AUTO_RESET_ON_FAILURE=true

# Process Management
PROCESS_KILL_TIMEOUT=30
PROCESS_WAIT_DELAY=5
